{{!< default}}

{{#author}}
<section class="c-archive-header">
    <div class="c-container">
        {{#if profile_image}}
            <img class="c-author-avatar" src="{{img_url profile_image size="s"}}" alt="{{name}}">
        {{/if}}
        <span class="c-archive-label">Autor</span>
        {{#if website}}
            <h1 class="c-archive-title"><a href="{{website}}" target="_blank" rel="noopener noreferrer">{{name}}</a></h1>
        {{else}}
            <h1 class="c-archive-title">{{name}}</h1>
        {{/if}}
        {{#if bio}}
            <p class="c-archive-desc">{{bio}}</p>
        {{/if}}
    </div>
</section>
{{/author}}

<section class="c-index" aria-label="Artículos del autor">
    <div class="c-container">
        <ol class="c-post-list" role="list">
            {{#foreach posts}}
                {{> "loop"}}
            {{/foreach}}
        </ol>
    </div>
</section>

{{pagination}}
