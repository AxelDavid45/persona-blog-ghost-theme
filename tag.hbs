{{!< default}}

{{#tag}}
<section class="c-archive-header">
    <div class="c-container">
        <span class="c-archive-label">Etiqueta</span>
        <h1 class="c-archive-title">{{name}}</h1>
        {{#if description}}
            <p class="c-archive-desc">{{description}}</p>
        {{/if}}
    </div>
</section>
{{/tag}}

<section class="c-index" aria-label="Artículos de la etiqueta">
    <div class="c-container">
        <ol class="c-post-list" role="list">
            {{#foreach posts}}
                {{> "loop"}}
            {{/foreach}}
        </ol>
    </div>
</section>

{{pagination}}
