<article class="c-article {{post_class}}">

    {{#match @page.show_title_and_feature_image}}
        <header class="c-article-header">
            <div class="c-container">
                {{#is "post"}}
                <div class="c-article-meta">
                    {{#if @custom.show_date}}
                    <time datetime="{{date format="YYYY-MM-DD"}}">
                        {{date published_at format="DD MMM. YYYY"}}
                    </time>
                    {{/if}}
                    {{#if @custom.show_reading_time}}
                    {{#if reading_time}}
                        {{#if @custom.show_date}}<span aria-hidden="true">&middot;</span>{{/if}}
                            <span>{{reading_time minute="% min de lectura" minutes="% min de lectura"}}</span>
                    {{/if}}
                    {{/if}}
                    {{#primary_tag}}
                        <span aria-hidden="true">&middot;</span>
                        <a class="c-article-tag" href="{{url}}">{{name}}</a>
                    {{/primary_tag}}
                </div>
                {{/is}}

                <h1 class="c-article-title">{{title}}</h1>

                {{#if custom_excerpt}}
                    <p class="c-article-excerpt">{{custom_excerpt}}</p>
                {{/if}}

                {{#if feature_image}}
                {{#unless no_image}}
                    <figure class="c-article-image">
                        <picture>
                            <source
                                srcset="{{img_url feature_image size="s" format="avif"}} 400w,
                                        {{img_url feature_image size="m" format="avif"}} 750w,
                                        {{img_url feature_image size="l" format="avif"}} 960w,
                                        {{img_url feature_image size="xl" format="avif"}} 1140w"
                                sizes="(min-width: 1200px) 720px, 92vw"
                                type="image/avif"
                            >
                            <source
                                srcset="{{img_url feature_image size="s" format="webp"}} 400w,
                                        {{img_url feature_image size="m" format="webp"}} 750w,
                                        {{img_url feature_image size="l" format="webp"}} 960w,
                                        {{img_url feature_image size="xl" format="webp"}} 1140w"
                                sizes="(min-width: 1200px) 720px, 92vw"
                                type="image/webp"
                            >
                            <img
                                srcset="{{> srcset}}"
                                sizes="(min-width: 1200px) 720px, 92vw"
                                src="{{img_url feature_image size="l"}}"
                                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                            >
                        </picture>
                        {{#if feature_image_caption}}
                            <figcaption>{{feature_image_caption}}</figcaption>
                        {{/if}}
                    </figure>
                {{/unless}}
                {{/if}}
            </div>
        </header>
    {{/match}}

    <div class="c-article-body gh-content gh-canvas">
        {{content}}
    </div>

    {{#is "post"}}
    <footer class="c-article-footer">
        <div class="c-container">
            <div class="c-share-bar">
                <span class="c-share-label">¿Te gustó este artículo?</span>
                <a class="c-btn c-btn-ghost c-btn-share" href="#/share" aria-label="Compartir este artículo">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                    Compartir
                </a>
            </div>

            <nav class="c-post-nav" aria-label="Navegación entre artículos">
                {{#prev_post}}
                    <a class="c-post-nav-link c-post-nav-prev" href="{{url}}">
                        <span class="c-post-nav-label">&larr; Anterior</span>
                        <span class="c-post-nav-title">{{title}}</span>
                    </a>
                {{/prev_post}}
                {{#next_post}}
                    <a class="c-post-nav-link c-post-nav-next" href="{{url}}">
                        <span class="c-post-nav-label">Siguiente &rarr;</span>
                        <span class="c-post-nav-title">{{title}}</span>
                    </a>
                {{/next_post}}
            </nav>

            {{#if @custom.show_author}}
            <div class="c-author-box">
                {{#foreach authors}}
                <div class="c-author-card">
                    {{#if profile_image}}
                        <a href="{{url}}" class="c-author-card-img">
                            <img src="{{img_url profile_image size="xs"}}" alt="{{name}}" loading="lazy">
                        </a>
                    {{/if}}
                    <div>
                        <span class="c-author-card-label">Escrito por</span>
                        <a href="{{url}}" class="c-author-card-name">{{name}}</a>
                    </div>
                </div>
                {{/foreach}}
            </div>
            {{/if}}
        </div>
    </footer>
    {{/is}}

</article>
