{
  "name": "cuaderno",
  "description": "A warm editorial Ghost theme — cinematic, single-column, Spanish-first",
  "version": "1.1.1",
  "private": true,
  "engines": {
    "ghost": ">=5.0.0"
  },
  "license": "MIT",
  "author": {
    "name": "Axel Espinosa",
    "email": "hello@axelespinosa.com"
  },
  "keywords": [
    "ghost",
    "theme",
    "ghost-theme"
  ],
  "config": {
    "posts_per_page": 10,
    "image_sizes": {
      "xs": {
        "width": 150
      },
      "s": {
        "width": 400
      },
      "m": {
        "width": 750
      },
      "l": {
        "width": 960
      },
      "xl": {
        "width": 1140
      },
      "xxl": {
        "width": 1920
      }
    },
    "card_assets": true,
    "custom": {
      "color_scheme": {
        "type": "select",
        "options": [
          "Auto",
          "Light",
          "Dark"
        ],
        "default": "Auto",
        "description": "Esquema de colores del sitio"
      },
      "title_font": {
        "type": "select",
        "options": [
          "Serif (Lora)",
          "Sans-serif (Source Sans)",
          "Modern serif"
        ],
        "default": "Serif (Lora)",
        "description": "Tipografía de títulos"
      },
      "feed_layout": {
        "type": "select",
        "options": [
          "Lista",
          "Lista compacta"
        ],
        "default": "Lista",
        "group": "homepage",
        "description": "Estilo de listado de posts"
      },
      "show_reading_time": {
        "type": "boolean",
        "default": true,
        "group": "post",
        "description": "Mostrar tiempo de lectura"
      },
      "show_author": {
        "type": "boolean",
        "default": true,
        "group": "post",
        "description": "Mostrar autor del post"
      },
      "show_date": {
        "type": "boolean",
        "default": true,
        "group": "post",
        "description": "Mostrar fecha de publicación"
      },
      "show_related_posts": {
        "type": "boolean",
        "default": true,
        "group": "post",
        "description": "Mostrar posts relacionados"
      },
      "show_comments": {
        "type": "boolean",
        "default": true,
        "group": "post",
        "description": "Mostrar sección de comentarios"
      }
    }
  },
  "scripts": {
    "dev": "gulp",
    "test": "gscan .",
    "zip": "gulp zip",
    "prepare": "husky",
    "version:patch": "pnpm version patch --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "version:major": "pnpm version major --no-git-tag-version"
  },
  "devDependencies": {
    "@tryghost/shared-theme-assets": "2.6.1",
    "autoprefixer": "10.4.27",
    "beeper": "2.1.0",
    "cssnano": "7.1.4",
    "gscan": "5.4.1",
    "gulp": "5.0.1",
    "gulp-concat": "2.6.1",
    "gulp-livereload": "4.0.2",
    "gulp-postcss": "10.0.0",
    "gulp-uglify": "3.0.2",
    "gulp-zip": "5.1.0",
    "husky": "^9.1.7",
    "ordered-read-streams": "2.0.0",
    "postcss": "8.5.8",
    "postcss-easy-import": "4.0.0",
    "pump": "3.0.4"
  }
}
